# =============================================================================
# Dependencies
# =============================================================================
node_modules/

# =============================================================================
# Build output
# =============================================================================
dist/

# =============================================================================
# Caches
# =============================================================================
.vite/
node_modules/.vite/
.vitest/

# =============================================================================
# TypeScript
# =============================================================================
*.tsbuildinfo

# =============================================================================
# Environment variables
# NOTE: Commit a .env.example so contributors know what values are needed.
# =============================================================================
.env
.env.*
.env.local
.env.*.local
!.env.example

# =============================================================================
# Local data (served from public/ in dev)
# The sample dataset at public/forecast-data/ IS tracked in the repo.
# Add any private / production forecast trees below.
# =============================================================================
public/data/config_*.yml
public/data/*.bak
public/data/*.nc
shapefiles/

# =============================================================================
# Logs
# =============================================================================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# =============================================================================
# Test coverage
# =============================================================================
coverage/

# =============================================================================
# Debug artifacts
# =============================================================================
debug-screenshots/
*.pid
*.seed
*.pid.lock

# =============================================================================
# Secrets & certificates — never commit these
# =============================================================================
*.pem
*.key
*.p12

# =============================================================================
# OS files
# =============================================================================
.DS_Store
Thumbs.db
Desktop.ini

# =============================================================================
# IDEs & editors
# Tip: commit .vscode/extensions.json and .vscode/settings.json if your team
# has agreed-upon defaults (add negation rules below if so).
# =============================================================================
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath
.settings/