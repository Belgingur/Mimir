# Required: MapTiler key for the Positron basemap.
VITE_MAPTILER_KEY=your-maptiler-key

# Optional: origin that serves the /forecast-data forecast catalog.
# Leave empty to load forecast data from this app's own origin.
VITE_INHOUSE_ROOT=

# Base URL for Belgingur wavegram PNG endpoints.
VITE_BELGINGUR_BASE_URL=https://wod.belgingur.is
